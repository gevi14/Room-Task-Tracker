rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only signed-in users (including anonymous) can read or write
    // the room-completion records. Adjust if you want stricter rules
    // (e.g. require email auth, or restrict by display name).
    match /completions/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
